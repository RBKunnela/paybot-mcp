# PayBot MCP server — environment configuration
#
# Copy this file to `.env` and replace the placeholder values. `.env` is
# gitignored and MUST NOT be committed; this example file ships only variable
# names, placeholders, and one-line descriptions.
#
# Mock mode: omit PAYBOT_WALLET_KEY and the server operates without a wallet;
# payment calls run in mock mode rather than signing on-chain transactions.

# PayBot API key. Required. Falls back to API_KEY if PAYBOT_API_KEY is unset.
PAYBOT_API_KEY=your-paybot-api-key

# Facilitator base URL. Optional; falls back to X402_FACILITATOR_URL, then to
# the PayBot-hosted default (https://api.paybotcore.com).
PAYBOT_FACILITATOR_URL=https://api.paybotcore.com

# Bot identifier. Optional; defaults to "mcp-agent".
PAYBOT_BOT_ID=your-bot-id

# Wallet private key for on-chain payments. Optional; omit for mock mode.
PAYBOT_WALLET_KEY=your-wallet-private-key
